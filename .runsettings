<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <Playwright>
    <BrowserName>chromium</BrowserName> 
    <!-- BrowserName>chromium / webkit / firefox</BrowserName-->
    <ExpectTimeout>5000</ExpectTimeout>
    <LaunchOptions>
      <Headless>false</Headless>
      <SlowMo>1000</SlowMo>
    </LaunchOptions>
  </Playwright>
</RunSettings>